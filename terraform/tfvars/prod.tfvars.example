project_id         = "your-prod-project"
region             = "asia-northeast1"
environment        = "prod"
api_image          = "asia-northeast1-docker.pkg.dev/your-prod-project/synthify/api:latest"
worker_image       = "asia-northeast1-docker.pkg.dev/your-prod-project/synthify/worker:latest"
uploads_bucket_name = "your-prod-project-synthify-uploads"
database_url_secret = "synthify-database-url-prod"
gemini_api_key_secret = "synthify-gemini-api-key-prod"
firebase_project_id = "your-prod-project"
cors_allowed_origins = "https://app.example.com"
gemini_model = "gemini-3.0-flash"
