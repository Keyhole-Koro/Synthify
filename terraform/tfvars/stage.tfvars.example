project_id         = "your-stage-project"
region             = "asia-northeast1"
environment        = "stage"
api_image          = "asia-northeast1-docker.pkg.dev/your-stage-project/synthify/api:latest"
worker_image       = "asia-northeast1-docker.pkg.dev/your-stage-project/synthify/worker:latest"
uploads_bucket_name = "your-stage-project-synthify-uploads"
database_url_secret = "synthify-database-url-stage"
worker_token_secret = "synthify-worker-token-stage"
firebase_project_id = "your-stage-project"
cors_allowed_origins = "https://stage.example.com"
