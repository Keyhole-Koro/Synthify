# ==============================================================================
# Synthify Environment Variables Example
# ==============================================================================
# Copy this file to .env and adjust the values as needed.
#
# Usage:
#   cp .env.example .env
# ==============================================================================

# --- Development Environment ---
# For local development with Docker Compose
LOCAL_UID=1000
LOCAL_GID=1000
FRONTEND_PORT=5173
BACKEND_PORT=8080
WORKER_PORT=8081
POSTGRES_PORT=5432
FIREBASE_AUTH_PORT=9099
FIREBASE_FIRESTORE_PORT=8282
GCS_PORT=4443

# --- Frontend Settings ---
# Note: Variables starting with NEXT_PUBLIC_ are exposed to the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-synthify
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-synthify.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-synthify.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:demo-synthify

# Local Emulators (Set to connect to Firebase Emulators)
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_URL=http://127.0.0.1:9099
NEXT_PUBLIC_FIREBASE_FIRESTORE_EMULATOR_HOST=127.0.0.1
NEXT_PUBLIC_FIREBASE_FIRESTORE_EMULATOR_PORT=8282

# --- Backend & Worker Settings ---
ENV=local
SERVICE_MODE=api # Use 'api' for backend, 'worker' for worker service
PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgres://synthify:synthify@localhost:5432/synthify?sslmode=disable

# Google Cloud Storage (Local Emulator)
GCS_BUCKET=synthify-uploads
GCS_EMULATOR_HOST=http://localhost:4443
GCS_UPLOAD_URL_BASE=http://localhost:4443/synthify-uploads
INTERNAL_GCS_UPLOAD_URL_BASE=http://gcs:4443/synthify-uploads

# Firebase Admin SDK / Emulator
FIREBASE_PROJECT_ID=demo-synthify
FIRESTORE_EMULATOR_HOST=localhost:8282
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Internal Service Communication
WORKER_BASE_URL=http://localhost:8081
INTERNAL_WORKER_TOKEN=dev-worker-token

# --- LLM (Gemini API) ---
# Get your API key from https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.0-flash
GEMINI_CACHE_ENABLED=true
GEMINI_CACHE_DIR=./.gemini-cache

# --- Log Viewer ---
LOG_VIEWER_PORT=5174
